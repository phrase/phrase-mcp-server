# Product selection:
# - Default: all products enabled
# - PHRASE_ENABLED_PRODUCTS supports: strings,tms,orchestrator,analytics
# - PHRASE_DISABLED_PRODUCTS removes from enabled set
# PHRASE_ENABLED_PRODUCTS=strings,tms,orchestrator,analytics
# PHRASE_DISABLED_PRODUCTS=
# Optional global region for default base URLs and TMS token exchange:
# PHRASE_REGION=eu

# Strings (defaults are provided for base URL and auth prefix)
PHRASE_STRINGS_TOKEN=your_phrase_strings_token
# Optional per-product region override:
# PHRASE_STRINGS_REGION=eu
# Optional override (defaults to https://api.phrase.com/v2)
# PHRASE_BASE_URL=https://api.phrase.com/v2
# PHRASE_STRINGS_BASE_URL=https://api.phrase.com/v2
# PHRASE_STRINGS_AUTH_HEADER=Authorization
# PHRASE_STRINGS_AUTH_PREFIX=token

# TMS
# PHRASE_TMS_BASE_URL=https://cloud.memsource.com/web/api2
# Optional per-product region override:
# PHRASE_TMS_REGION=eu
# Unified token exchange inputs (recommended):
# PHRASE_API_TOKEN=your_phrase_api_token
# Legacy direct token input (optional fallback if you do not use PHRASE_API_TOKEN):
# PHRASE_TMS_TOKEN=
# PHRASE_TMS_AUTH_HEADER=Authorization
# PHRASE_TMS_AUTH_PREFIX=Bearer
# Optional: custom user agent for TMS requests
# PHRASE_TMS_USER_AGENT=phrase-mcp-server/0.1.0

# Orchestrator
# PHRASE_ORCHESTRATOR_BASE_URL=
# PHRASE_ORCHESTRATOR_REGION=eu
# PHRASE_ORCHESTRATOR_TOKEN=
# PHRASE_ORCHESTRATOR_AUTH_HEADER=Authorization
# PHRASE_ORCHESTRATOR_AUTH_PREFIX=Bearer

# Analytics
# PHRASE_ANALYTICS_BASE_URL=
# PHRASE_ANALYTICS_REGION=eu
# PHRASE_ANALYTICS_TOKEN=
# PHRASE_ANALYTICS_AUTH_HEADER=Authorization
# PHRASE_ANALYTICS_AUTH_PREFIX=Bearer
